  "content_html": "<div class=\"rich-text\"><h3 class=\"font_3 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:30px;\"><span class=\"color_25 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\" style=\"font-weight:bold;\"><span class=\"wixui-rich-text__text\" style=\"font-size:30px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\">DigiPoint בקר מתוכנת דיגיטלי</span></span></span></span></h3></div>\n<div class=\"rich-text\"><p class=\"font_8 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\">DigiPoint הוא בקר עצמאי הכולל שעון פנימי שניתן לתכנות באמצעות דיאגרמת סולם ורוטינות תוכנה שפותחו לראש לשימושים שונים , הבקר תוכנן במיוחד לבקרה וניטור מערכות תאורה ומערכות אלקטרו מכניות במבני ציבור ותעשייה.</span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixGuard wixui-rich-text__text\">​</span></span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\">הבקר מותאם במיוחד לבתי מלון, מבני משרדים, בתי חולים, אוניברסיטאות, מוזאונים, תעשייה נקייה ועוד.</span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixGuard wixui-rich-text__text\">​</span></span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\">הבקר מאפשר תכנות בצורה קלה יעילה וזריזה, וכולל פרוטוקולי תקשורת פתוחים ומקובלים כגון:</span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\">Modbus RTU + IP as well as BACnet IP + MSTP.</span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixGuard wixui-rich-text__text\">​</span></span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\">הבקר מאפשר קריאת פולסים מהירים והפקתם (למערכות מנייה) וכן יכולת גלישה אליו באמצעות דפדפן.</span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixGuard wixui-rich-text__text\">​</span></span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\">יכולות אלו מעמידות את הבקר DigiPoint כבקר מאוד אטרקטיבי הן כבקר עצמאי והן ככרטיס הרחבה לבקר Veropoint.</span></span></p></div>\n<div class=\"rich-text\"><h3 class=\"font_3 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:40px;\"><span class=\"wixui-rich-text__text\" style=\"font-weight:bold;\"><span style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋\">움,dotum,helvetica,sans-serif;\" class=\"wixui-rich-text__text\"&gt;מוצרים קשורים</span></span></h3></div>\n<div class=\"rich-text\"><p class=\"font_7 wixui-rich-text__text\" style=\"font-size:22px; text-align:center;\"><span class=\"wixui-rich-text__text\" style=\"font-size:22px;\"><span class=\"wixui-rich-text__text\" style=\"font-weight:bold;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"color:#FFFFFF;\"> ישומי בקרה בע״מ</span></span></span></span></p></div>\n<div class=\"rich-text\"><p class=\"font_7 wixui-rich-text__text\" style=\"font-size:20px;\"><span class=\"wixui-rich-text__text\" style=\"font-weight:bold;\"><span class=\"wixui-rich-text__text\" style=\"font-size:20px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"color:#FFFFFF;\">יצירת קשר</span></span></span></span></p>\n<p class=\"font_7 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:20px; text-align:left;\"><span class=\"wixui-rich-text__text\" style=\"color:rgb(255, 255, 255); font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif; font-size:16px;\">טלפון: +972-3-6474998</span><span class=\"wixui-rich-text__text\" style=\"color:rgb(255, 255, 255); font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif; font-size:16px;\">​</span></p>\n<p class=\"font_7 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:20px; text-align:left;\"><span class=\"wixui-rich-text__text\" style=\"color:rgb(255, 255, 255); font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif; font-size:16px;\">פקס: +972-3-6474598</span></p>\n<p class=\"font_7 wixui-rich-text__text\" dir=\"rtl\" style=\"font-size:20px; text-align:left;\"><span class=\"wixui-rich-text__text\" style=\"color:rgb(255, 255, 255); font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif; font-size:16px;\">דואר אלקטרוני: <a class=\"wixui-rich-text__text\" data-auto-recognition=\"true\" href=\"mailto:cal@ddc.co.il\">cal@ddc.co.il</a></span></p></div>\n<div class=\"rich-text\"><p class=\"font_7 wixui-rich-text__text\" style=\"font-size:20px; text-align:center;\"><span class=\"wixui-rich-text__text\" style=\"font-weight:bold;\"><span class=\"wixui-rich-text__text\" style=\"font-size:20px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"color:#FFFFFF;\">שעות פתיחה</span></span></span></span></p>\n<p class=\"font_7 wixui-rich-text__text\" style=\"font-size:16px; text-align:center;\"><span class=\"wixui-rich-text__text\" style=\"font-size:16px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"color:#FFFFFF;\">ישומי בקרה בע״מ</span></span></span></p>\n<p class=\"font_7 wixui-rich-text__text\" style=\"font-size:20px; text-align:center;\"><span class=\"wixui-rich-text__text\" style=\"font-size:16px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"color:#FFFFFF;\">ראשון - חמישי</span></span></span></p>\n<p class=\"font_7 wixui-rich-text__text\" style=\"font-size:20px; text-align:center;\"><span class=\"wixui-rich-text__text\" style=\"font-size:16px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial