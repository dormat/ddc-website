  "content_html": "<div class=\"rich-text\"><h3 class=\"font_3 wixui-rich-text__text\" dir=\"ltr\" style=\"font-size:30px;\"><span class=\"color_25 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\" style=\"font-size:30px;\"><span class=\"wixui-rich-text__text\" style=\"font-weight:bold;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\">VeroPoint controller with expansion cards</span></span></span></span></h3></div>\n<div class=\"rich-text\"><p class=\"font_8 wixui-rich-text__text\" dir=\"ltr\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"color:#787878;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"background-color:#FFFFFE;\">VeroPoint is a standalone and universal programmable controller<br class=\"wixui-rich-text__text\"/>(PLC/DDC) specially designed for monitoring and control purposes<br class=\"wixui-rich-text__text\"/>of heating, ventilation, and cooling systems (HVAC), control systems<br class=\"wixui-rich-text__text\"/>Electricity and energy and closed loop control.</span></span></span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"ltr\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"color:#787878;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"background-color:#FFFFFE;\"><span class=\"wixGuard wixui-rich-text__text\">​</span></span></span></span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"ltr\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"color:#787878;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"background-color:#FFFFFE;\">VeroPoint is the optimal solution for system control and monitoring<br class=\"wixui-rich-text__text\"/>In public buildings, industry, hospitals, hotels.</span></span></span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"ltr\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"color:#787878;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"background-color:#FFFFFE;\"><span class=\"wixGuard wixui-rich-text__text\">​</span></span></span></span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"ltr\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"color:#787878;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"background-color:#FFFFFE;\">VeroPoint is a standalone controller that includes a battery-backed clock<br class=\"wixui-rich-text__text\"/>The controller software is stored in non-volatile memory that cannot be deleted.</span></span></span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"ltr\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"color:#787878;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"background-color:#FFFFFE;\"><span class=\"wixGuard wixui-rich-text__text\">​</span></span></span></span></span></p>\n<p class=\"font_8 wixui-rich-text__text\" dir=\"ltr\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"color:#787878;\"><span class=\"wixui-rich-text__text\" style=\"font-size:18px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"background-color:#FFFFFE;\">The VeroPoint controller includes a graphical screen that can be programmed as an HMI<br class=\"wixui-rich-text__text\"/>For convenient and friendly local operation for the purposes of operating schedules and receiving<br class=\"wixui-rich-text__text\"/>real time data.</span></span></span></span></p></div>\n<div class=\"rich-text\"><h3 class=\"font_3 wixui-rich-text__text\" dir=\"ltr\" style=\"font-size:40px;\"><span class=\"wixui-rich-text__text\" style=\"font-weight:bold;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\">Related products</span></span></h3></div>\n<div class=\"rich-text\"><p class=\"font_7 wixui-rich-text__text\" style=\"font-size:22px; text-align:center;\"><span class=\"wixui-rich-text__text\" style=\"font-size:22px;\"><span class=\"wixui-rich-text__text\" style=\"font-weight:bold;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"color:#FFFFFF;\">Control Applications Ltd</span></span></span></span></p></div>\n<div class=\"rich-text\"><p class=\"font_7 wixui-rich-text__text\" style=\"font-size:20px;\"><span class=\"wixui-rich-text__text\" style=\"font-weight:bold;\"><span class=\"wixui-rich-text__text\" style=\"font-size:20px;\"><span class=\"wixui-rich-text__text\" style=\"font-family:arial,ｍｓ ｐゴシック,ms pgothic,돋움,dotum,helvetica,sans-serif;\"><span class=\"wixui-rich-text__text\" style=\"color:#FFFFFF;\">making contact</span></span></span></span></p>\n<p class=\"font_7 wixui-rich-text__text\" d